# ===========================================
# BlackPayments Wallet - Production Environment Variables
# ===========================================

# Environment
NODE_ENV=production

# Application
NEXT_PUBLIC_APP_URL=https://blackpayments.com
APP_NAME=BlackPayments Wallet
APP_VERSION=1.0.0

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_PROJECT_ID=your-project-id

# Blockchain RPC URLs (Production)
ALCHEMY_API_KEY=your-alchemy-api-key
INFURA_API_KEY=your-infura-api-key
INFURA_API_SECRET=your-infura-api-secret
CLOUDFLARE_ETH_API_KEY=your-cloudflare-eth-api-key

# TRON Network
TRONGRID_API_KEY=your-trondgrid-api-key
TRON_NODE_URL=https://api.trongrid.io

# Wallet Connect
NEXT_PUBLIC_WALLET_CONNECT_PROJECT_ID=your-walletconnect-project-id

# HSM (Hardware Security Module) - REQUIRED IN PRODUCTION
HSM_API_URL=https://hsm.blackpayments.com
HSM_API_KEY=your-hsm-api-key
HSM_HSM_PIN=your-hsm-pin
HSM_KEY_LABEL=blackpayments-custodial

# Custody Configuration
CUSTODY_KEY_MANAGER_MODE=http-hsm
CUSTODY_ALLOW_LOCAL_HD=false

# JWT Configuration
JWT_SECRET=your-jwt-secret-min-32-chars
JWT_EXPIRY=7d

# Encryption
WALLET_ENCRYPTION_KEY=your-encryption-key-min-32-chars

# CSRF Protection
CSRF_SECRET=your-csrf-secret-min-32-chars

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token
REDIS_URL=redis://your-redis-host:6379

# Sentry Error Tracking
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
SENTRY_ORG=your-org
SENTRY_PROJECT=your-project

# Email Service (Production)
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=your-sendgrid-api-key
EMAIL_FROM=noreply@blackpayments.com
EMAIL_FROM_NAME=BlackPayments Wallet

# Push Notifications
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_SUBJECT=mailto:admin@blackpayments.com

# Payment Providers
MOONPAY_API_KEY=your-moonpay-api-key
MOONPAY_SECRET_KEY=your-moonpay-secret-key
MOONPAY_ENVIRONMENT=production
TRANSAK_API_KEY=your-transak-api-key
TRANSAK_ENVIRONMENT=production

# KYC Provider
KYC_PROVIDER=sumsub
SUMSUB_API_TOKEN=your-sumsub-token
SUMSUB_SECRET_KEY=your-sumsub-secret
SUMSUB_BASE_URL=https://api.sumsub.com

# Monitoring
DATADOG_API_KEY=your-datadog-api-key
DATADOG_SITE=datadoghq.com

# Feature Flags
ENABLE_TESTNET=false
ENABLE_DEV_MODE=false
ENABLE_MOCK_SERVICES=false
ENABLE_DEBUG_LOGGING=false

# Security
ALLOWED_ORIGINS=https://blackpayments.com,https://app.blackpayments.com
TRUSTED_PROXIES=your-load-balancer-ips

# Backup
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30
BACKUP_S3_BUCKET=blackpayments-backups
BACKUP_S3_REGION=us-east-1
BACKUP_S3_ACCESS_KEY=your-backup-access-key
BACKUP_S3_SECRET_KEY=your-backup-secret-key

# Compliance
COMPLIANCE_MODE=strict
KYC_REQUIRED=true
AML_SCREENING_ENABLED=true
SANCTIONS_SCREENING_ENABLED=true
