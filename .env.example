                                                                           # BlackPayments Wallet - Production Environment Variables
# Copy to .env.local and replace every placeholder with deployment values.
# NEXT_PUBLIC_* values are exposed to the browser. Never expose server secrets.

# ========================
# SUPABASE
# ========================
# Required. Get from Supabase dashboard: Settings > API.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ========================
# APP / HOSTING
# ========================
# Required in production. Use your real public domain, no trailing slash.
NEXT_PUBLIC_APP_URL=https://wallet.blackpayments.example
NEXT_PUBLIC_APP_NAME=BlackPayments
NEXT_PUBLIC_DEFAULT_CHAIN=tron

# Vercel/Netlify deployments can set this automatically, but setting it keeps
# payment links stable across platforms.
NEXT_PUBLIC_VERCEL_URL=

# ========================
# WALLETCONNECT (Optional - DApp browser)
# ========================
# NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# ========================
# MOONPAY (Optional - fiat on/off ramp)
# ========================
# NEXT_PUBLIC_MOONPAY_PUBLIC_KEY=pk_live_xxx
# MOONPAY_SECRET_KEY=sk_live_xxx

# ========================
# 1INCH (Optional - token swap)
# ========================
# NEXT_PUBLIC_1INCH_API_KEY=

# ========================
# ALCHEMY (Optional but recommended for AA and prices)
# ========================
# NEXT_PUBLIC_ALCHEMY_API_KEY=
# ALCHEMY_API_KEY=

# ========================
# BLOCKCHAIN RPC URLs
# ========================
# Production RPC endpoints. Configure private or rate-limited endpoints where
# possible; public mainnet fallbacks are used only when these are not set.
NEXT_PUBLIC_ETHEREUM_RPC=https://eth-mainnet.g.alchemy.com/v2/your-ethereum-api-key
NEXT_PUBLIC_BSC_RPC=https://bsc-mainnet.g.alchemy.com/v2/your-bsc-api-key
NEXT_PUBLIC_POLYGON_RPC=https://polygon-mainnet.g.alchemy.com/v2/your-polygon-api-key
NEXT_PUBLIC_ARBITRUM_RPC=https://arb-mainnet.g.alchemy.com/v2/your-arbitrum-api-key
NEXT_PUBLIC_OPTIMISM_RPC=https://opt-mainnet.g.alchemy.com/v2/your-optimism-api-key
NEXT_PUBLIC_AVALANCHE_RPC=https://avalanche-mainnet.g.alchemy.com/v2/your-avalanche-api-key
NEXT_PUBLIC_CELO_RPC=https://celo-mainnet.publicnode.com
NEXT_PUBLIC_LINEA_RPC=https://linea-mainnet.g.alchemy.com/v2/your-linea-api-key
NEXT_PUBLIC_BASE_RPC=https://base-mainnet.g.alchemy.com/v2/your-base-api-key
NEXT_PUBLIC_SOLANA_RPC=https://solana-mainnet.g.alchemy.com/v2/your-solana-api-key
NEXT_PUBLIC_TRON_RPC=https://tron-mainnet.g.alchemy.com/v2/your-tron-api-key

# Server-only RPC overrides for custodial signing/indexing jobs.
# Do not expose these values in NEXT_PUBLIC_* variables.
ETHEREUM_RPC_URL=https://your-private-ethereum-rpc
BSC_RPC_URL=https://your-private-bsc-rpc
POLYGON_RPC_URL=https://your-private-polygon-rpc
ARBITRUM_RPC_URL=https://your-private-arbitrum-rpc
OPTIMISM_RPC_URL=https://your-private-optimism-rpc
AVALANCHE_RPC_URL=https://your-private-avalanche-rpc
CELO_RPC_URL=https://your-private-celo-rpc
LINEA_RPC_URL=https://your-private-linea-rpc
BASE_RPC_URL=https://your-private-base-rpc
SOLANA_RPC_URL=https://your-private-solana-rpc
TRON_RPC_URL=https://your-private-tron-rpc
TRON_FULL_NODE=https://your-private-tron-full-node
TRON_SOLIDITY_NODE=https://your-private-tron-solidity-node
TRON_EVENT_SERVER=https://your-private-tron-event-server

# ========================
# CUSTODIAL WALLET MVP
# ========================
# Production must use an HSM/KMS/MPC custody adapter. Do not use local-hd with
# real funds. The HTTP HSM adapter is the built-in production path.
CUSTODIAL_KEY_MANAGER_MODE=http-hsm
CUSTODIAL_HSM_BASE_URL=https://hsm.example.internal
CUSTODIAL_HSM_TOKEN=your-hsm-api-token

# Required only if your deployment uses a custom in-process HSM/KMS adapter.
# CUSTODIAL_KEY_MANAGER_MODE=hsm

# Redis/Upstash REST for withdrawal locks and idempotency.
# Required in production; the in-memory fallback is development-only.
REDIS_REST_URL=https://your-redis-rest-url
REDIS_REST_TOKEN=your-redis-rest-token
# Upstash aliases are also supported:
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# ========================
# EXPLORER URLs
# ========================
NEXT_PUBLIC_ETHERSCAN_URL=https://etherscan.io
NEXT_PUBLIC_BSCSCAN_URL=https://bscscan.com
NEXT_PUBLIC_POLYGONSCAN_URL=https://polygonscan.com

# ========================
# BLACKPAYMENTS PAYMENT GATEWAY
# ========================
# Payment invoice URLs are generated from NEXT_PUBLIC_APP_URL.
# Configure merchant webhook endpoints in the Payments UI.

# ========================
# ANALYTICS / NOTIFICATIONS (Optional)
# ========================
# NEXT_PUBLIC_GA_TRACKING_ID=
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=
