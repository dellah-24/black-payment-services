# Production npm configuration
registry=https://registry.npmjs.org/
save-exact=true
save-prefix=
legacy-peer-deps=false
engine-strict=true
fund=false
audit=false
progress=false
loglevel=warn
prefer-online=true
cache-min=86400
package-lock=true
package-lock-only=false
shrinkwrap=false
scripts-prepend-node-path=true
ignore-scripts=false
unsafe-perm=false
# userconfig=/dev/null
# globalconfig=/dev/null
cache=/tmp/.npm
tmp=/tmp/.npm-tmp
# prefix=/usr/local

# Security
audit-level=high
save-dev=false

# Performance
maxsockets=50
fetch-retries=2
fetch-retry-mintimeout=10000
fetch-retry-maxtimeout=60000

# Production only
# production=true
# only=production
